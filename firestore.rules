rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function cleanEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function roleDoc() {
      return get(/databases/$(database)/documents/roleAssignments/$(cleanEmail()));
    }

    function roleData() {
      return exists(/databases/$(database)/documents/roleAssignments/$(cleanEmail()))
        ? roleDoc().data
        : {};
    }

    function privileges() {
      return roleData().privileges is list ? roleData().privileges : [];
    }

    function dashboards() {
      return roleData().dashboardAccess is list ? roleData().dashboardAccess : [];
    }

    function hasPrivilege(name) {
      return signedIn() && privileges().hasAny([name]);
    }

    function hasDashboard(name) {
      return signedIn() && dashboards().hasAny([name]);
    }

    function isSuperadmin() {
      return signedIn() && (
        hasPrivilege('manage_system') ||
        hasDashboard('superadmin') ||
        roleData().role in ['Founder', 'Co-Founder'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Founder', 'Co-Founder'])
      );
    }

    function canEvaluate() {
      return signedIn() && (
        isSuperadmin() ||
        hasPrivilege('evaluate_submissions') ||
        hasPrivilege('award_points') ||
        hasPrivilege('close_verified_problems') ||
        hasDashboard('evaluator') ||
        roleData().role in ['Evaluator', 'Innovator']
      );
    }

    function canAwardPoints() {
      return signedIn() && (
        isSuperadmin() ||
        hasPrivilege('award_points') ||
        roleData().role in ['Evaluator', 'Innovator']
      );
    }

    function isSelfUser(userId) {
      return signedIn() && (
        request.auth.uid == userId ||
        request.resource.data.uid == request.auth.uid ||
        request.resource.data.email == cleanEmail()
      );
    }

    function immutableIdentityUnchanged() {
      return (!('uid' in resource.data) || request.resource.data.uid == resource.data.uid)
        && (!('email' in resource.data) || request.resource.data.email == resource.data.email);
    }

    function validUsernameValue(value) {
      return value is string && value.matches('^[a-z0-9_]{3,30}$');
    }

    function usernameReservationPath(username) {
      return /databases/$(database)/documents/usernames/$(username);
    }

    function usernameReservedFor(userId) {
      return validUsernameValue(request.resource.data.username)
        && request.resource.data.usernameLower == request.resource.data.username
        && existsAfter(usernameReservationPath(request.resource.data.usernameLower))
        && getAfter(usernameReservationPath(request.resource.data.usernameLower)).data.uid == userId;
    }

    function protectedUserFieldsUnchanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'username',
        'usernameLower',
        'specialty',
        'initials',
        'avatar',
        'profilePicture',
        'banner',
        'bio',
        'country',
        'website',
        'linkedin',
        'github',
        'portfolio',
        'profileAccent',
        'availability',
        'referralCode',
        'updatedAt'
      ]);
    }

    function awardUserFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'points',
        'impactPoints',
        'experience',
        'solved',
        'badges',
        'stats',
        'awardHistory',
        'lastContributionAward',
        'taskSubmissionHistory',
        'lastTaskAward',
        'platformExperienceHistory',
        'lastPlatformExperienceAward',
        'updatedAt'
      ]);
    }

    function userCreateFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'id',
        'uid',
        'email',
        'displayName',
        'username',
        'usernameLower',
        'role',
        'adminRole',
        'privileges',
        'dashboardAccess',
        'isSupportingPartner',
        'joinedDate',
        'stats',
        'badges',
        'bio',
        'specialty',
        'initials',
        'avatar',
        'profilePicture',
        'banner',
        'country',
        'website',
        'linkedin',
        'github',
        'portfolio',
        'profileAccent',
        'availability',
        'points',
        'impactPoints',
        'experience',
        'solved',
        'referralCode',
        'referredBy',
        'referredByCode',
        'referralTier',
        'referralBadgeLevel',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validBadgeField() {
      return !('badges' in request.resource.data)
        || request.resource.data.badges == []
        || request.resource.data.badges == ['first-step'];
    }

    function contributionAwardShape() {
      let award = request.resource.data.lastContributionAward;
      return award is map
        && award.problemId is string
        && award.points is number
        && award.experience is number
        && award.points > 0
        && award.points <= 50
        && award.experience >= 0
        && award.experience <= 1000;
    }

    function contributionAwardUpdate() {
      let award = request.resource.data.lastContributionAward;
      let previousHistory = resource.data.awardHistory is list ? resource.data.awardHistory : [];
      let nextHistory = request.resource.data.awardHistory is list ? request.resource.data.awardHistory : [];
      let previousStats = resource.data.stats is map ? resource.data.stats : {};
      let nextStats = request.resource.data.stats is map ? request.resource.data.stats : {};
      let previousImpact = previousStats.impactPoints is number ? previousStats.impactPoints : 0;
      let previousTotalImpact = previousStats.totalImpactPoints is number ? previousStats.totalImpactPoints : 0;
      let previousSolved = previousStats.problemsSolved is number ? previousStats.problemsSolved : 0;
      let previousExperience = previousStats.experience is number ? previousStats.experience : 0;
      let problemPath = /databases/$(database)/documents/problems/$(award.problemId);
      return canAwardPoints()
        && awardUserFieldsOnly()
        && (!('points' in request.resource.data) || !('points' in resource.data) || request.resource.data.points == resource.data.points)
        && (!('impactPoints' in request.resource.data) || !('impactPoints' in resource.data) || request.resource.data.impactPoints == resource.data.impactPoints)
        && (!('experience' in request.resource.data) || !('experience' in resource.data) || request.resource.data.experience == resource.data.experience)
        && (!('solved' in request.resource.data) || !('solved' in resource.data) || request.resource.data.solved == resource.data.solved)
        && nextStats.impactPoints == previousImpact + award.points
        && nextStats.totalImpactPoints == previousTotalImpact + award.points
        && nextStats.problemsSolved == previousSolved + 1
        && nextStats.experience == previousExperience + award.experience
        && exists(problemPath)
        && get(problemPath).data.status == 'Solved'
        && get(problemPath).data.contributors is list
        && (
          get(problemPath).data.contributors.hasAny([request.resource.data.username]) ||
          get(problemPath).data.contributors.hasAny([request.resource.data.displayName])
        )
        && nextHistory.size() == previousHistory.size() + 1
        && nextHistory.hasAll(previousHistory)
        && nextHistory.hasAny([award.problemId])
        && !previousHistory.hasAny([award.problemId]);
    }

    function taskAwardShape() {
      let award = request.resource.data.lastTaskAward;
      return award is map
        && award.submissionId is string
        && award.taskId is string
        && award.points is number
        && award.experience is number
        && award.points >= 0
        && award.points <= 100
        && award.experience >= 0
        && award.experience <= 5000;
    }

    function taskAwardUpdate() {
      let award = request.resource.data.lastTaskAward;
      let previousHistory = resource.data.taskSubmissionHistory is list ? resource.data.taskSubmissionHistory : [];
      let nextHistory = request.resource.data.taskSubmissionHistory is list ? request.resource.data.taskSubmissionHistory : [];
      let previousStats = resource.data.stats is map ? resource.data.stats : {};
      let nextStats = request.resource.data.stats is map ? request.resource.data.stats : {};
      let previousImpact = previousStats.impactPoints is number ? previousStats.impactPoints : 0;
      let previousTotalImpact = previousStats.totalImpactPoints is number ? previousStats.totalImpactPoints : 0;
      let previousExperience = previousStats.experience is number ? previousStats.experience : 0;
      let previousCompleted = previousStats.communityTasksCompleted is number ? previousStats.communityTasksCompleted : 0;
      let submissionPath = /databases/$(database)/documents/taskSubmissions/$(award.submissionId);
      return canAwardPoints()
        && awardUserFieldsOnly()
        && nextStats.impactPoints == previousImpact + award.points
        && nextStats.totalImpactPoints == previousTotalImpact + award.points
        && nextStats.experience == previousExperience + award.experience
        && nextStats.communityTasksCompleted == previousCompleted + 1
        && exists(submissionPath)
        && get(submissionPath).data.status == 'Approved'
        && get(submissionPath).data.memberUid == request.resource.data.uid
        && get(submissionPath).data.taskId == award.taskId
        && get(submissionPath).data.expReward == award.experience
        && get(submissionPath).data.impactPointReward == award.points
        && nextHistory.size() == previousHistory.size() + 1
        && nextHistory.hasAll(previousHistory)
        && nextHistory.hasAny([award.submissionId])
        && !previousHistory.hasAny([award.submissionId]);
    }

    function platformExperienceAwardShape() {
      let award = request.resource.data.lastPlatformExperienceAward;
      return award is map
        && award.action is string
        && award.experience is number
        && award.experience > 0
        && award.experience <= 500;
    }

    function platformExperienceAwardUpdate() {
      let award = request.resource.data.lastPlatformExperienceAward;
      let previousHistory = resource.data.platformExperienceHistory is list ? resource.data.platformExperienceHistory : [];
      let nextHistory = request.resource.data.platformExperienceHistory is list ? request.resource.data.platformExperienceHistory : [];
      let previousStats = resource.data.stats is map ? resource.data.stats : {};
      let nextStats = request.resource.data.stats is map ? request.resource.data.stats : {};
      let previousExperience = previousStats.experience is number ? previousStats.experience : 0;
      return signedIn()
        && (isSelfUser(request.auth.uid) || canAwardPoints())
        && awardUserFieldsOnly()
        && (!('points' in request.resource.data) || !('points' in resource.data) || request.resource.data.points == resource.data.points)
        && (!('impactPoints' in request.resource.data) || !('impactPoints' in resource.data) || request.resource.data.impactPoints == resource.data.impactPoints)
        && (!('solved' in request.resource.data) || !('solved' in resource.data) || request.resource.data.solved == resource.data.solved)
        && (!('impactPoints' in nextStats) || !('impactPoints' in previousStats) || nextStats.impactPoints == previousStats.impactPoints)
        && (!('totalImpactPoints' in nextStats) || !('totalImpactPoints' in previousStats) || nextStats.totalImpactPoints == previousStats.totalImpactPoints)
        && (!('problemsSolved' in nextStats) || !('problemsSolved' in previousStats) || nextStats.problemsSolved == previousStats.problemsSolved)
        && nextStats.experience == previousExperience + award.experience
        && nextHistory.size() == previousHistory.size() + 1
        && nextHistory.hasAll(previousHistory)
        && nextHistory.hasAny([award.action])
        && !previousHistory.hasAny([award.action])
        && award.action in ['profile_completion', 'first_login', 'daily_visit', 'problem_post', 'referral_milestone'];
    }

    function marketplacePurchaseShape() {
      let purchase = request.resource.data.lastCosmeticPurchase;
      return purchase is map
        && purchase.cosmeticId is string
        && purchase.price is number
        && purchase.price >= 0;
    }

    function marketplacePurchaseUpdate() {
      let purchase = request.resource.data.lastCosmeticPurchase;
      let previousStats = resource.data.stats is map ? resource.data.stats : {};
      let nextStats = request.resource.data.stats is map ? request.resource.data.stats : {};
      let previousImpact = previousStats.impactPoints is number ? previousStats.impactPoints : 0;
      let previousTotalImpact = previousStats.totalImpactPoints is number ? previousStats.totalImpactPoints : 0;
      let nextTotalImpact = nextStats.totalImpactPoints is number ? nextStats.totalImpactPoints : 0;
      let previousOwned = ('ownedCosmetics' in resource.data) && (resource.data.ownedCosmetics is list) ? resource.data.ownedCosmetics : [];
      let nextOwned = ('ownedCosmetics' in request.resource.data) && (request.resource.data.ownedCosmetics is list) ? request.resource.data.ownedCosmetics : [];
      let cosmeticPath = /databases/$(database)/documents/cosmetics/$(purchase.cosmeticId);
      return signedIn()
        && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'points', 'impactPoints', 'stats', 'ownedCosmetics', 'lastCosmeticPurchase', 'updatedAt', 'avatar', 'banner', 'badges'
           ])
        && nextStats.impactPoints == previousImpact - purchase.price
        && (!('points' in request.resource.data) || request.resource.data.points == previousImpact - purchase.price)
        && (!('impactPoints' in request.resource.data) || request.resource.data.impactPoints == previousImpact - purchase.price)
        && nextTotalImpact == previousTotalImpact
        && exists(cosmeticPath)
        && get(cosmeticPath).data.acquisition == 'Marketplace'
        && get(cosmeticPath).data.price == purchase.price
        && get(cosmeticPath).data.enabled == true
        && nextOwned.size() == previousOwned.size() + 1
        && nextOwned.hasAll(previousOwned)
        && nextOwned.hasAny([purchase.cosmeticId])
        && !previousOwned.hasAny([purchase.cosmeticId]);
    }

    function validSelfCreate(userId) {
      return userId == request.auth.uid
        && userCreateFieldsOnly()
        && isSelfUser(userId)
        && usernameReservedFor(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == cleanEmail()
        && (!('role' in request.resource.data) || request.resource.data.role == 'Member')
        && (!('adminRole' in request.resource.data) || request.resource.data.adminRole == '')
        && (!('privileges' in request.resource.data) || request.resource.data.privileges == [])
        && (!('dashboardAccess' in request.resource.data) || request.resource.data.dashboardAccess == [])
        && (!('isSupportingPartner' in request.resource.data) || request.resource.data.isSupportingPartner == false)
        && validBadgeField()
        && (!('points' in request.resource.data) || request.resource.data.points == 0)
        && (!('impactPoints' in request.resource.data) || request.resource.data.impactPoints == 0)
        && (!('experience' in request.resource.data) || request.resource.data.experience == 0)
        && (!('solved' in request.resource.data) || request.resource.data.solved == 0)
        && (!('stats' in request.resource.data) || (
          (!('experience' in request.resource.data.stats) || request.resource.data.stats.experience == 0) &&
          (!('impactPoints' in request.resource.data.stats) || request.resource.data.stats.impactPoints == 0) &&
          (!('totalImpactPoints' in request.resource.data.stats) || request.resource.data.stats.totalImpactPoints == 0) &&
          (!('problemsSolved' in request.resource.data.stats) || request.resource.data.stats.problemsSolved == 0) &&
          (!('problemsIdentified' in request.resource.data.stats) || request.resource.data.stats.problemsIdentified == 0) &&
          (!('helpfulResponses' in request.resource.data.stats) || request.resource.data.stats.helpfulResponses == 0) &&
          (!('knowledgeContributions' in request.resource.data.stats) || request.resource.data.stats.knowledgeContributions == 0)
        ));
    }

    function isProblemOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function validProblemCreate(problemId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'title',
          'category',
          'friction',
          'tried',
          'ripple',
          'date',
          'status',
          'solver',
          'ownerUid',
          'ownerName',
          'ownerUsername',
          'contributors',
          'contributorReviews',
          'suggestedRemovals',
          'evaluatorAwards',
          'solvedBy',
          'complexity',
          'ownerReview',
          'winnerXP',
          'attemptXP',
          'winnerEXP',
          'attemptEXP',
          'clones',
          'views',
          'archiveHoursSaved',
          'archiveRippleReach',
          'archiveClones',
          'archiveViews',
          'archiveSummary',
          'archiveOutcome',
          'archiveEditedBy',
          'archiveEditedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'Pending Review'
        && request.resource.data.contributors is list
        && request.resource.data.contributors == []
        && (!('contributorReviews' in request.resource.data) || request.resource.data.contributorReviews == [])
        && (!('suggestedRemovals' in request.resource.data) || request.resource.data.suggestedRemovals == [])
        && (!('winnerXP' in request.resource.data) || request.resource.data.winnerXP == 0)
        && (!('attemptXP' in request.resource.data) || request.resource.data.attemptXP == 0)
        && (!('winnerEXP' in request.resource.data) || request.resource.data.winnerEXP == 0)
        && (!('attemptEXP' in request.resource.data) || request.resource.data.attemptEXP == 0)
        && (!('clones' in request.resource.data) || request.resource.data.clones == 0)
        && (!('views' in request.resource.data) || request.resource.data.views >= 0 && request.resource.data.views <= 1)
        && (!('archiveHoursSaved' in request.resource.data) || request.resource.data.archiveHoursSaved == 0)
        && (!('archiveRippleReach' in request.resource.data) || request.resource.data.archiveRippleReach == 0)
        && (!('archiveClones' in request.resource.data) || request.resource.data.archiveClones == 0)
        && (!('archiveViews' in request.resource.data) || request.resource.data.archiveViews >= 0 && request.resource.data.archiveViews <= 1)
        && (!('archiveSummary' in request.resource.data) || request.resource.data.archiveSummary == '')
        && (!('archiveOutcome' in request.resource.data) || request.resource.data.archiveOutcome == '')
        && (!('archiveEditedBy' in request.resource.data) || request.resource.data.archiveEditedBy == '')
        && (!('archiveEditedAt' in request.resource.data) || request.resource.data.archiveEditedAt == '')
        && (!('evaluatorAwards' in request.resource.data) || request.resource.data.evaluatorAwards == []);
    }

    function participantOnlyUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contributors', 'updatedAt'])
        && resource.data.status == 'Open'
        && request.resource.data.contributors is list
        && resource.data.contributors is list
        && request.resource.data.contributors.size() >= resource.data.contributors.size()
        && request.resource.data.contributors.hasAll(resource.data.contributors);
    }

    function ownerReviewUpdate() {
      return isProblemOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'ownerReview',
          'contributorReviews',
          'suggestedRemovals',
          'updatedAt'
        ])
        && request.resource.data.status == 'Pending Evaluation';
    }

    function evaluatorProblemUpdate() {
      return canEvaluate()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'friction',
          'tried',
          'ripple',
          'resolution',
          'status',
          'updatedAt'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) ||
          request.resource.data.status in ['Open', 'Needs Revision', 'Rejected', 'Pending Review', 'Pending Evaluation', 'Closed by Owner']
        );
    }

    function awardProblemUpdate() {
      return canAwardPoints()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'contributors',
          'evaluatorAwards',
          'solvedBy',
          'winnerXP',
          'attemptXP',
          'winnerEXP',
          'attemptEXP',
          'updatedAt'
        ])
        && request.resource.data.status == 'Solved';
    }

    function taskSubmissionOwner() {
      return signedIn() && (
        resource.data.memberUid == request.auth.uid ||
        resource.data.memberEmail == cleanEmail()
      );
    }

    function taskSubmissionCreateOwner() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'taskId',
          'taskTitle',
          'category',
          'memberUid',
          'memberEmail',
          'memberName',
          'memberUsername',
          'description',
          'reflection',
          'attachments',
          'links',
          'proofHash',
          'status',
          'expReward',
          'impactPointReward',
          'evaluatorComments',
          'evaluatorUid',
          'evaluatorName',
          'submittedAt',
          'reviewedAt',
          'updatedAt',
          'history'
        ])
        && request.resource.data.memberUid == request.auth.uid
        && request.resource.data.memberEmail == cleanEmail()
        && request.resource.data.status == 'Pending Verification'
        && request.resource.data.taskId is string
        && request.resource.data.description is string
        && request.resource.data.attachments is list
        && request.resource.data.links is list
        && request.resource.data.expReward is number
        && request.resource.data.impactPointReward is number;
    }

    function taskSubmissionOwnerUpdate() {
      return taskSubmissionOwner()
        && resource.data.status in ['Information Requested', 'In Progress', 'Pending Verification']
        && request.resource.data.memberUid == resource.data.memberUid
        && request.resource.data.memberEmail == resource.data.memberEmail
        && request.resource.data.taskId == resource.data.taskId
        && request.resource.data.status == 'Pending Verification'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'reflection',
          'attachments',
          'links',
          'proofHash',
          'status',
          'submittedAt',
          'updatedAt',
          'history'
        ]);
    }

    function evaluatorTaskSubmissionUpdate() {
      return canEvaluate()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'evaluatorComments',
          'evaluatorUid',
          'evaluatorName',
          'reviewedAt',
          'updatedAt',
          'history'
        ])
        && request.resource.data.status in ['Approved', 'Rejected', 'Information Requested', 'Flagged'];
    }

    function notificationOwner() {
      return signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.email == cleanEmail()
      );
    }

    function notificationCreateAllowed() {
      return signedIn() && (
        canEvaluate() ||
        isSuperadmin() ||
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.email == cleanEmail()
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if validSelfCreate(userId) || isSuperadmin();
      allow update: if (
        (isSelfUser(userId) && protectedUserFieldsUnchanged() && immutableIdentityUnchanged() && usernameReservedFor(userId)) ||
        (contributionAwardShape() && contributionAwardUpdate()) ||
        (taskAwardShape() && taskAwardUpdate()) ||
        (platformExperienceAwardShape() && platformExperienceAwardUpdate()) ||
        (marketplacePurchaseShape() && marketplacePurchaseUpdate()) ||
        isSuperadmin()
      );
      allow delete: if isSuperadmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSuperadmin() || (
        signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'email', 'username', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == cleanEmail()
        && request.resource.data.username == username
        && validUsernameValue(username)
      );
      allow update: if isSuperadmin() || (
        signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'email', 'username', 'createdAt', 'updatedAt'])
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.username == username
        && validUsernameValue(username)
      );
      allow delete: if isSuperadmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /problems/{problemId} {
      allow read: if true;
      allow create: if validProblemCreate(problemId) || canEvaluate();
      allow update: if participantOnlyUpdate()
        || ownerReviewUpdate()
        || evaluatorProblemUpdate()
        || awardProblemUpdate()
        || isSuperadmin();
      allow delete: if isSuperadmin();
    }

    match /roleAssignments/{email} {
      allow read: if signedIn() && (cleanEmail() == email || isSuperadmin());
      allow write: if isSuperadmin();
    }

    match /supportingPartners/{partnerId} {
      allow read: if true;
      allow create: if isSuperadmin()
        || (signedIn() && request.resource.data.ownerUid == request.auth.uid && hasDashboard('supportingPartner'));
      allow update: if isSuperadmin()
        || (signedIn() && resource.data.ownerUid == request.auth.uid && request.resource.data.ownerUid == resource.data.ownerUid && hasDashboard('supportingPartner'));
      allow delete: if isSuperadmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /taskCategories/{categoryId} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /communityTasks/{taskId} {
      allow read: if resource.data.status == 'Published' || signedIn();
      allow write: if isSuperadmin();
    }

    match /taskSubmissions/{submissionId} {
      allow read: if taskSubmissionOwner() || canEvaluate() || isSuperadmin();
      allow create: if taskSubmissionCreateOwner() || canEvaluate();
      allow update: if taskSubmissionOwnerUpdate() || evaluatorTaskSubmissionUpdate() || isSuperadmin();
      allow delete: if isSuperadmin();
    }

    match /notifications/{notificationId} {
      allow read: if notificationOwner() || isSuperadmin();
      allow create: if notificationCreateAllowed();
      allow update: if notificationOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);
      allow delete: if isSuperadmin();
    }

    match /impactPointTransactions/{transactionId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isSuperadmin());
      allow create, update, delete: if isSuperadmin() || canAwardPoints();
    }

    match /rewardRedemptions/{redemptionId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isSuperadmin());
      allow write: if false;
    }

    match /rewardsCatalog/{rewardId} {
      allow read: if true;
      allow write: if false;
    }

    match /referrals/{referralId} {
      allow read: if signedIn() && (resource.data.inviterUid == request.auth.uid || resource.data.inviteeUid == request.auth.uid || isSuperadmin());
      allow create: if signedIn() && (request.resource.data.inviteeUid == request.auth.uid || isSuperadmin()) && request.resource.data.inviterUid != request.resource.data.inviteeUid;
      allow update, delete: if isSuperadmin();
    }

    match /cosmetics/{cosmeticId} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
